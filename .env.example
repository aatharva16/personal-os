# ============================================================
# Personal AI OS — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── OpenRouter ────────────────────────────────────────────────
# One key covers all models. Get it at: openrouter.ai → Dashboard → Keys
OPENROUTER_API_KEY=sk-or-...

# Heartbeat model — pinned to a free tier model (zero cost).
# Recommended: meta-llama/llama-3.3-70b-instruct:free
# (Better instruction-following than nemotron for structured tasks)
HEARTBEAT_MODEL_ID=meta-llama/llama-3.3-70b-instruct:free

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN_CHIEF=<Chief of Staff bot token from @BotFather>
TELEGRAM_BOT_TOKEN_NEWS=<News agent bot token from @BotFather>

# Your numeric Telegram user ID (message @userinfobot to find it)
TELEGRAM_ALLOWED_USER_ID=<your numeric user ID>

# ── Search APIs ───────────────────────────────────────────────
# Required: Brave Search — used by OpenClaw's native web_search tool.
# Get a key at: api.search.brave.com → Data for AI plan ($5/month free credit, ~1,000 queries).
BRAVE_API_KEY=BSA...

# Supplementary: Tavily — agents can call https://api.tavily.com/search directly via HTTP
# for structured, AI-optimised results. Not used by OpenClaw's native search integration.
# Sign up at: app.tavily.com/sign-up (1,000 free credits/month, no credit card)
TAVILY_API_KEY=tvly-...

# Supplementary: Serper.dev — agents can call directly for Google Search results.
# Sign up at: serper.dev (2,500 free queries on signup, then $1/1,000)
SERPER_API_KEY=...

# ── Gateway bind ─────────────────────────────────────────────
# loopback = localhost only (local dev)
# lan      = all LAN interfaces (required for Tailscale/Hetzner production)
GATEWAY_BIND=loopback

# ── Tailscale ─────────────────────────────────────────────────
# Set to: tailscale ip -4
TAILSCALE_IP=

# Set to: tailscale serve status (e.g. personal-os.tail6c91e4.ts.net)
TAILSCALE_HOSTNAME=

# ── OpenClaw Workspace ────────────────────────────────────────
OPENCLAW_WORKSPACE_ROOT=/home/clawuser/.openclaw

# ── Miniflux ───────────────────────────────────────────────────
# Generate strong passwords: openssl rand -hex 16
MINIFLUX_DB_PASS=<strong random password>
MINIFLUX_ADMIN_PASS=<your admin UI password>
# Create API key in Miniflux UI after first launch: Settings → API Keys
MINIFLUX_API_KEY=<generated in Miniflux UI>
# Direct DB URL for pipeline script
MINIFLUX_DATABASE_URL=postgres://miniflux:<MINIFLUX_DB_PASS>@localhost/miniflux
MINIFLUX_URL=http://localhost:8080

# ── Paperclip ──────────────────────────────────────────────
# AI company orchestration platform (port 3100)
# Uses embedded PostgreSQL by default (~/.paperclip/instances/default/db)
PAPERCLIP_PORT=3100
# Full URL agents use to reach Paperclip (always localhost — tailscale serve
# handles Tailnet exposure, so agents and external devices both just work)
PAPERCLIP_URL=http://localhost:3100
# Company ID — deploy.sh auto-discovers hired agents and provisions API keys.
# Find it: npx paperclipai company list
PAPERCLIP_COMPANY_ID=

