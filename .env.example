# ============================================================
# Personal AI OS — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── NadirClaw (model router) ─────────────────────────────────
# Simple prompts go to the cheap model; complex ones to the smart model.
# NadirClaw uses LiteLLM under the hood — prefix with provider if needed
# (e.g. "openrouter/google/gemini-flash-1.5-8b" for OpenRouter routing).

NADIRCLAW_SIMPLE_MODEL=google/gemini-flash-1.5-8b
NADIRCLAW_COMPLEX_MODEL=anthropic/claude-3.5-sonnet

# Classification confidence threshold (default 0.06).
# Lower = more prompts routed to the complex model (safer, more expensive).
NADIRCLAW_CONFIDENCE_THRESHOLD=0.06

# NadirClaw server port — openclaw.json.template references this.
NADIRCLAW_PORT=8856

# ── Provider API Keys ─────────────────────────────────────────
# Provide whichever keys match your chosen models above.
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Ollama base URL (only needed if using ollama/* models)
# OLLAMA_API_BASE=http://localhost:11434

# ── Telegram ──────────────────────────────────────────────────
# Create three bots via @BotFather — one per agent.
TELEGRAM_BOT_TOKEN_HEALTH=...
TELEGRAM_BOT_TOKEN_STOCKS=...
TELEGRAM_BOT_TOKEN_EMAIL=...

# Your numeric Telegram user ID (only this user can message the bots).
# Find it by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_ID=...

# ── OpenClaw Workspace ────────────────────────────────────────
# Root directory where openclaw agent workspaces are stored on the VM.
# deploy.sh syncs agents/ → $OPENCLAW_WORKSPACE_ROOT/workspace-<name>
OPENCLAW_WORKSPACE_ROOT=/home/clawuser/.openclaw
