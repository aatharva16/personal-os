# ============================================================
# Personal AI OS — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── OpenRouter ────────────────────────────────────────────────
# One key covers all models. Get it at: openrouter.ai → Dashboard → Keys
# Agent messages use openrouter/auto (server-side intelligent routing).
OPENROUTER_API_KEY=sk-or-...

# Heartbeat model — pinned to a free tier model.
# Heartbeats never go through the auto router, so they cost nothing.
# This is the bare OpenRouter model ID (no "openrouter/" prefix).
HEARTBEAT_MODEL_ID=nvidia/nemotron-3-super-120b-a12b:free

# ── Telegram ─────────────────────────────────────────────────
# One bot per agent — create both via @BotFather.
TELEGRAM_BOT_TOKEN_CHIEF=<Chief of Staff bot token from @BotFather>
TELEGRAM_BOT_TOKEN_NEWS=<News agent bot token from @BotFather>

# Your numeric Telegram user ID (find it by messaging @userinfobot).
# Both bots use dmPolicy:"allowlist" — only this user ID can DM them.
TELEGRAM_ALLOWED_USER_ID=<your numeric user ID>

# ── Gateway bind ─────────────────────────────────────────────
# Use named modes (not raw IPs — legacy values rejected since v2026.2.26):
# loopback = localhost only (default, safe for local dev)
# lan      = all LAN interfaces (required for Tailscale/Hetzner production access)
GATEWAY_BIND=loopback

# ── Tailscale ─────────────────────────────────────────────────
# Tailscale IP of this machine — used in gateway.controlUi.allowedOrigins.
# Set to: tailscale ip -4
# Leave empty for local dev (falls back harmlessly to 127.0.0.1).
TAILSCALE_IP=

# Tailscale HTTPS hostname — from: tailscale serve status (e.g. personal-os.tail6c91e4.ts.net)
# Used in gateway.controlUi.allowedOrigins for the HTTPS Tailscale Serve URL.
# Leave empty for local dev.
TAILSCALE_HOSTNAME=

# ── Brave Search ─────────────────────────────────────────────
# Used by the web_search tool in all agents.
# Get a key at: brave.com/search/api → Data for Search plan ($5/month free credit).
BRAVE_API_KEY=BSA...

# ── OpenClaw Workspace ────────────────────────────────────────
# Root directory where agent workspaces are stored on the server.
# deploy.sh syncs agents/<name>/ → $OPENCLAW_WORKSPACE_ROOT/workspace-<name>/
OPENCLAW_WORKSPACE_ROOT=/home/clawuser/.openclaw
