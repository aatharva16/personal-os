# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=...

# Telegram User ID — only this user can interact with the bot
TELEGRAM_ALLOWED_USER_ID=...

# --- Model Routing Thresholds ---
# Complexity score (0–100) above which Claude 3.5 Sonnet is used
NADIR_COMPLEXITY_THRESHOLD=60

# Models
MODEL_CHEAP=google/gemini-flash-1.5-8b
MODEL_SMART=anthropic/claude-3.5-sonnet

# --- Memory ---
# Token count at which context is compacted
MEMORY_COMPACTION_THRESHOLD=8000

# --- Heartbeat ---
# Interval in minutes between heartbeat runs (default 55)
HEARTBEAT_INTERVAL_MINUTES=55
