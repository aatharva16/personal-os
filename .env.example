# ============================================================
# Personal AI OS — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── NadirClaw (model router) ─────────────────────────────────
# NadirClaw classifies every prompt (sentence-embedding, ~10ms) and routes:
#   simple prompts  → NADIRCLAW_SIMPLE_MODEL  (cheap/free)
#   complex prompts → NADIRCLAW_COMPLEX_MODEL (smart)
#
# Both models are on OpenRouter — prefix with "openrouter/" so LiteLLM
# resolves them correctly. See openrouter.ai/models for available IDs.
#
# NADIRCLAW_SIMPLE_MODEL: using llama-4-scout:free (free tier, no cost).
# Gemini Flash 1.5 8B is no longer listed on OpenRouter; llama-4-scout is
# a comparable lightweight model and is free.

NADIRCLAW_SIMPLE_MODEL=openrouter/meta-llama/llama-4-scout:free
NADIRCLAW_COMPLEX_MODEL=openrouter/anthropic/claude-sonnet-4-5

# ── Heartbeat Model ───────────────────────────────────────────
# Used for keep-alive pings — should be a free/cheap model.
# This is the bare OpenRouter model ID (no "openrouter/" prefix).
# It is used both as the provider model id and prefixed with "openrouter/"
# in the heartbeat config so heartbeats bypass NadirClaw routing entirely.
HEARTBEAT_MODEL_ID=google/gemini-2.0-flash-exp:free

# Classification confidence threshold (default 0.06).
# Lower = more prompts routed to complex model (safer, more expensive).
NADIRCLAW_CONFIDENCE_THRESHOLD=0.06

# NadirClaw port — openclaw.json.template references this.
NADIRCLAW_PORT=8856

# ── OpenRouter API Key ────────────────────────────────────────
# One key covers all models (Gemini, DeepSeek, Claude, etc.)
# Get it at: openrouter.ai → Dashboard → Keys
OPENROUTER_API_KEY=sk-or-...

# ── Optional: Direct provider keys ───────────────────────────
# Only needed if you want to bypass OpenRouter for specific models.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Telegram ──────────────────────────────────────────────────
# Single bot for all 6 agents. Create via @BotFather.
# Switch agents in chat with /agent <id> (e.g. /agent stocks).
TELEGRAM_BOT_TOKEN=...

# Your numeric Telegram user ID (the bot will only respond to you).
# Find it by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_ID=...

# ── OpenClaw Workspace ────────────────────────────────────────
# Root directory where agent workspaces are stored on the server.
# deploy.sh syncs agents/<name>/ → $OPENCLAW_WORKSPACE_ROOT/workspace-<name>/
OPENCLAW_WORKSPACE_ROOT=/home/clawuser/.openclaw
