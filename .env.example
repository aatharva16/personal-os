# ============================================================
# Personal AI OS — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── OpenRouter ────────────────────────────────────────────────
# One key covers all models. Get it at: openrouter.ai → Dashboard → Keys
OPENROUTER_API_KEY=sk-or-...

# Heartbeat model — pinned to a free tier model (zero cost).
# Recommended: meta-llama/llama-3.3-70b-instruct:free
# (Better instruction-following than nemotron for structured tasks)
HEARTBEAT_MODEL_ID=meta-llama/llama-3.3-70b-instruct:free

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN_CHIEF=<Chief of Staff bot token from @BotFather>
TELEGRAM_BOT_TOKEN_NEWS=<News agent bot token from @BotFather>

# Your numeric Telegram user ID (message @userinfobot to find it)
TELEGRAM_ALLOWED_USER_ID=<your numeric user ID>

# ── Search APIs ───────────────────────────────────────────────
# Primary: Tavily — 1,000 free credits/month, no credit card required
# Sign up at: app.tavily.com/sign-up
TAVILY_API_KEY=tvly-...

# Overflow: Serper.dev — 2,500 free queries on signup, then $1/1,000
# Sign up at: serper.dev
SERPER_API_KEY=...

# ── Gateway bind ─────────────────────────────────────────────
# loopback = localhost only (local dev)
# lan      = all LAN interfaces (required for Tailscale/Hetzner production)
GATEWAY_BIND=loopback

# ── Tailscale ─────────────────────────────────────────────────
# Set to: tailscale ip -4
TAILSCALE_IP=

# Set to: tailscale serve status (e.g. personal-os.tail6c91e4.ts.net)
TAILSCALE_HOSTNAME=

# ── OpenClaw Workspace ────────────────────────────────────────
OPENCLAW_WORKSPACE_ROOT=/home/clawuser/.openclaw
