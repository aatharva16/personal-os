// openclaw.json — Personal AI OS Gateway Configuration
// Template file: deploy.sh runs `envsubst` to produce ~/.openclaw/openclaw.json
// DO NOT commit the rendered file — only commit this template.
// See .env.example for all required environment variables.

{
  // ── Model Providers ────────────────────────────────────────────────────────
  // All inference goes through OpenRouter. Regular agent messages use
  // openrouter/auto, which is OpenRouter's server-side intelligent router
  // (powered by NotDiamond) — it picks the most cost-effective model per
  // prompt automatically. Model restrictions (Anthropic-only, no Opus) are
  // configured as account-wide defaults in the OpenRouter Plugins dashboard.
  //
  // Heartbeats are pinned to a free model so they never consume the auto
  // router's budget allocation.
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            // openrouter/auto — OpenRouter's server-side intelligent router.
            // Routes each prompt to the most cost-effective model automatically.
            // Restrict the model pool (Anthropic-only, no Opus) in the
            // OpenRouter Plugins settings page as an account-wide default.
            "id": "auto",
            "name": "OpenRouter Auto (intelligent routing)",
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8096
          },
          {
            // Free tier model used for heartbeats — zero cost, no rate-limit surprises.
            // Controlled by HEARTBEAT_MODEL_ID in .env (bare OpenRouter model ID, no "openrouter/" prefix).
            "id": "${HEARTBEAT_MODEL_ID}",
            "name": "Heartbeat model (free)",
            "input": ["text"],
            "contextWindow": 10000000,
            "maxTokens": 8096
          }
        ]
      }
    }
  },

  // ── Agent Definitions ──────────────────────────────────────────────────────
  // Default model is OpenRouter Auto — server-side intelligent routing picks
  // the most cost-effective model per prompt automatically.
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/auto",
        "fallbacks": []
      },
      "heartbeat": {
        // Pinned to a free OpenRouter model — heartbeats never go through the
        // auto router so they never consume budget.
        "model": "openrouter/${HEARTBEAT_MODEL_ID}"
      },
      "compaction": {
        "mode": "default",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 8000,
          "prompt": "Extract key facts, decisions, open items and preferences into memory/YYYY-MM-DD.md. Bullet points only. Omit small talk.",
          "systemPrompt": "Memory curator. Extract only what is worth remembering long-term."
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "6h",
        "keepLastAssistants": 3
      },
      "bootstrapMaxChars": 3000,
      "bootstrapTotalMaxChars": 15000,
      "maxConcurrent": 2,
      "subagents": { "maxConcurrent": 4 }
    },

    "list": [
      {
        "id": "health",
        "name": "Health Tracker",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-health"
      },
      {
        "id": "stocks",
        "name": "Stock Analyser",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-stocks"
      },
      {
        "id": "portfolio",
        "name": "Portfolio Checker",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-portfolio"
      },
      {
        "id": "news",
        "name": "News Feed",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-news"
      },
      {
        "id": "jobs",
        "name": "Job Searcher",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-jobs"
      },
      {
        "id": "email",
        "name": "Email Organiser",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-email"
      }
    ]
  },

  // ── Telegram Channel ───────────────────────────────────────────────────────
  // Single bot for all agents. Switch active agent with /agent <id> in chat.
  // Only TELEGRAM_ALLOWED_USER_ID can message the bot.
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${TELEGRAM_ALLOWED_USER_ID}"],
      "streaming": "partial"
    }
  },

  // ── Default Agent Binding ─────────────────────────────────────────────────
  // All Telegram DMs go to health by default.
  // User switches with /agent <id> (e.g. /agent stocks, /agent email).
  "bindings": [
    {
      "agentId": "health",
      "match": { "channel": "telegram" }
    }
  ],

  // ── Gateway ────────────────────────────────────────────────────────────────
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback"
  },

  // ── Logging ────────────────────────────────────────────────────────────────
  "logging": {
    "redactSensitive": "tools"
  }
}
