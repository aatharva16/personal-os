// openclaw.json — Personal AI OS Gateway Configuration
// Template file: deploy.sh runs `envsubst` to produce ~/.openclaw/openclaw.json
// DO NOT commit the rendered file — only commit this template.
// See .env.example for all required environment variables.

{
  // ── Model Providers ────────────────────────────────────────────────────────
  // All inference is routed through NadirClaw (localhost:8856), which
  // classifies prompt complexity and forwards to cheap or expensive models
  // on OpenRouter. NadirClaw presents an OpenAI-compatible API.
  //
  // OpenRouter is also registered directly so that heartbeats can be pinned
  // to a free model without going through NadirClaw routing (which could
  // occasionally classify a heartbeat as "complex" and spend budget).
  "models": {
    "mode": "merge",
    "providers": {
      "nadirclaw": {
        "baseUrl": "http://127.0.0.1:${NADIRCLAW_PORT}/v1",
        "apiKey": "local",
        "api": "openai-completions",
        "models": [
          {
            "id": "auto",
            "name": "auto (NadirClaw routed)",
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8096
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            // Free tier model used for heartbeats — zero cost, no rate-limit surprises.
            // Controlled by HEARTBEAT_MODEL_ID in .env (bare OpenRouter model ID, no "openrouter/" prefix).
            "id": "${HEARTBEAT_MODEL_ID}",
            "name": "Heartbeat model (free)",
            "input": ["text"],
            "contextWindow": 10000000,
            "maxTokens": 8096
          }
        ]
      }
    }
  },

  // ── Agent Definitions ──────────────────────────────────────────────────────
  // Default model is NadirClaw auto-routing (cheap for simple, smart for complex).
  // Stocks and Portfolio override to complex-only because numerical/financial
  // accuracy is worth the extra cost.
  "agents": {
    "defaults": {
      "model": {
        "primary": "nadirclaw/auto",
        "fallbacks": []
      },
      "heartbeat": {
        // Pinned to a free OpenRouter model — bypasses NadirClaw so heartbeats
        // never accidentally consume budget from the complex model quota.
        "model": "openrouter/${HEARTBEAT_MODEL_ID}"
      },
      "compaction": {
        "mode": "default",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 8000,
          "prompt": "Extract key facts, decisions, open items and preferences into memory/YYYY-MM-DD.md. Bullet points only. Omit small talk.",
          "systemPrompt": "Memory curator. Extract only what is worth remembering long-term."
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "6h",
        "keepLastAssistants": 3
      },
      "bootstrapMaxChars": 3000,
      "bootstrapTotalMaxChars": 15000,
      "maxConcurrent": 2,
      "subagents": { "maxConcurrent": 4 }
    },

    "list": [
      {
        "id": "health",
        "name": "Health Tracker",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-health"
      },
      {
        "id": "stocks",
        "name": "Stock Analyser",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-stocks"
      },
      {
        "id": "portfolio",
        "name": "Portfolio Checker",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-portfolio"
      },
      {
        "id": "news",
        "name": "News Feed",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-news"
      },
      {
        "id": "jobs",
        "name": "Job Searcher",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-jobs"
      },
      {
        "id": "email",
        "name": "Email Organiser",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-email"
      }
    ]
  },

  // ── Telegram Channel ───────────────────────────────────────────────────────
  // Single bot for all agents. Switch active agent with /agent <id> in chat.
  // Only TELEGRAM_ALLOWED_USER_ID can message the bot.
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${TELEGRAM_ALLOWED_USER_ID}"],
      "streaming": "partial"
    }
  },

  // ── Default Agent Binding ─────────────────────────────────────────────────
  // All Telegram DMs go to health by default.
  // User switches with /agent <id> (e.g. /agent stocks, /agent email).
  "bindings": [
    {
      "agentId": "health",
      "match": { "channel": "telegram" }
    }
  ],

  // ── Gateway ────────────────────────────────────────────────────────────────
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback"
  },

  // ── Logging ────────────────────────────────────────────────────────────────
  "logging": {
    "redactSensitive": "tools"
  }
}
