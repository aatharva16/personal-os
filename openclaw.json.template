// openclaw.json — Personal AI OS Gateway Configuration
// Template file: deploy.sh runs `envsubst` to produce ~/.openclaw/openclaw.json
// DO NOT commit the rendered file — only commit this template.
// See .env.example for all required environment variables.

{
  // ── Model Providers ────────────────────────────────────────────────────────
  // All inference goes through OpenRouter.
  //
  // Agent messages use openrouter/auto — OpenRouter's server-side intelligent
  // router (powered by NotDiamond). It picks the most cost-effective model per
  // prompt automatically. Configure model restrictions (e.g. Anthropic-only,
  // no Opus) in the OpenRouter Plugins dashboard as account-wide defaults.
  //
  // Heartbeats are pinned to a hardcoded free model so they never consume the
  // auto-router's budget.
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            // openrouter/auto — server-side intelligent routing.
            // Picks the most cost-effective model per prompt automatically.
            "id": "auto",
            "name": "OpenRouter Auto (intelligent routing)",
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8096
          },
          {
            // Free tier model used exclusively for heartbeats — zero cost.
            // Set HEARTBEAT_MODEL_ID in .env (bare OpenRouter model ID, no prefix).
            "id": "${HEARTBEAT_MODEL_ID}",
            "name": "Heartbeat model (free)",
            "input": ["text"],
            "contextWindow": 10000000,
            "maxTokens": 8096
          }
        ]
      }
    }
  },

  // ── Agent Definitions ──────────────────────────────────────────────────────
  "agents": {
    "defaults": {
      "model": {
        // openrouter/auto handles cheap-vs-premium routing server-side.
        "primary": "openrouter/auto",
        "fallbacks": []
      },
      // Shared heartbeat defaults — model and lightContext are inherited by
      // every agent heartbeat block. Per-agent blocks only need to specify
      // what differs (every, target, accountId).
      "heartbeat": {
        // Pinned to the free model — zero cost for all heartbeats.
        "model": "openrouter/${HEARTBEAT_MODEL_ID}",
        "lightContext": true
      },
      "compaction": {
        "mode": "default",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 8000,
          "prompt": "Extract key facts, decisions, open items and preferences into memory/YYYY-MM-DD.md. Bullet points only. Omit small talk.",
          "systemPrompt": "Memory curator. Extract only what is worth remembering long-term."
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "6h",
        "keepLastAssistants": 3
      },
      "bootstrapMaxChars": 3000,
      "bootstrapTotalMaxChars": 15000,
      "maxConcurrent": 2,
      "subagents": { "maxConcurrent": 4 }
    },

    "list": [
      {
        // Chief of Staff — primary entry point for general requests.
        "id": "chief",
        "name": "Chief of Staff",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-chief",
        // Grants chief permission to spawn tasks to these agents via sessions_spawn.
        // sessions_send (agentToAgent) is intentionally omitted — bug #5813 in
        // openclaw 2026.3.13 causes sessions_spawn to silently stall when
        // tools.agentToAgent.enabled is set. Re-enable once that is fixed.
        "subagents": { "allowAgents": ["news"] },
        // NOTE: Add "quant", "scout", "ideation" here in Phase 3, 4, 5 respectively
        // Inherits model/lightContext from agents.defaults.heartbeat.
        "heartbeat": { "every": "30m" }
      },
      {
        // News — daily briefings, current events, tech/markets/geopolitics.
        // Has its own Telegram bot and pushes briefings directly to the user.
        "id": "news",
        "name": "News",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}/workspace-news",
        // Inherits model/lightContext from agents.defaults.heartbeat.
        "heartbeat": {
          "every": "4h",
          // Route heartbeat delivery through the news bot.
          "target": "telegram",
          "accountId": "news-bot"
        }
      }
    ]
  },

  // ── Channels ───────────────────────────────────────────────────────────────
  "channels": {
    // ── Telegram ─────────────────────────────────────────────────────────────
    // One bot per agent — each agent has its own Telegram entry point.
    // Only TELEGRAM_ALLOWED_USER_ID can DM either bot.
    // Create both bots via @BotFather and set TELEGRAM_BOT_TOKEN_CHIEF and
    // TELEGRAM_BOT_TOKEN_NEWS in .env.
    "telegram": {
      "enabled": true,
      "accounts": {
        // dmPolicy and allowFrom must be set per-account (not at channel root).
        // allowlist: only TELEGRAM_ALLOWED_USER_ID can DM either bot.
        // Bug #25793 (allowlist silently dropping messages) was present 2026.2.23–2026.3.x;
        // fixed as of 2026.3.13.
        "chief-bot": { "botToken": "${TELEGRAM_BOT_TOKEN_CHIEF}", "dmPolicy": "allowlist", "allowFrom": ["${TELEGRAM_ALLOWED_USER_ID}"], "streaming": "partial" },
        "news-bot":  { "botToken": "${TELEGRAM_BOT_TOKEN_NEWS}",  "dmPolicy": "allowlist", "allowFrom": ["${TELEGRAM_ALLOWED_USER_ID}"], "streaming": "partial" }
      }
    }
    // WebChat control panel is auto-configured by OpenClaw on the gateway port.
    // Do not add a "webchat" entry here — OpenClaw rejects it as an unknown channel id.
    // Access: http://localhost:18789 (local) or http://<tailscale-ip>:18789 (prod).
    // Paste the gateway token shown in startup logs when the UI prompts for it.
  },

  // ── Agent Bindings ─────────────────────────────────────────────────────────
  // Each bot routes directly to its own agent — no cross-agent routing.
  "bindings": [
    { "agentId": "chief", "match": { "channel": "telegram", "accountId": "chief-bot" } },
    { "agentId": "news",  "match": { "channel": "telegram", "accountId": "news-bot"  } }
  ],

  // ── Gateway ────────────────────────────────────────────────────────────────
  // GATEWAY_BIND controls the network interface (use named modes, not raw IPs):
  //   loopback  = localhost only (default — safe for local dev)
  //   lan       = all LAN interfaces (required for Tailscale/Hetzner production access)
  //
  // controlUi.allowedOrigins — required since v2026.2.26 when bind=lan.
  // TAILSCALE_IP: set to `tailscale ip -4` output in production .env.
  // For local dev leave TAILSCALE_IP unset; it falls back to 127.0.0.1 (harmless duplicate).
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "${GATEWAY_BIND}",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://${TAILSCALE_IP}:18789",
        "https://${TAILSCALE_HOSTNAME}"
      ]
    }
  },

  // ── Web Tools ──────────────────────────────────────────────────────────────
  // OpenClaw's built-in search only supports: brave, perplexity, grok, gemini, kimi.
  // Tavily and Serper are used at the agent skill level via TAVILY_API_KEY / SERPER_API_KEY
  // env vars injected into each workspace — not via the built-in provider mechanism.
  "tools": {
    "web": {
      "search": {
        "enabled": false
      }
    }
  },

  // ── Logging ────────────────────────────────────────────────────────────────
  "logging": {
    "redactSensitive": "tools"
  }
}
